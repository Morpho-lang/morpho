// Mean Sq curvature
import implicitmesh
import plot

// Make a sphere
var impl = ImplicitMeshBuilder(fn (x,y,z) x^2+y^2+z^2-1)
var mesh = impl.build(stepsize=0.25)

// Mean Squared curvature
var lmc = AltMeanCurvatureSq()
//print (lmc.total(mesh)-12.477)<1e-4 // expect: true

print lmc.total(mesh)
